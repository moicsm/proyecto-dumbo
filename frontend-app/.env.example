# ===============================================
# VARIABLES DE ENTORNO - EJEMPLO
# ===============================================
# 
# IMPORTANTE: Este es un archivo de ejemplo
# Copia este archivo como .env y configura tus valores reales
# NUNCA subas el archivo .env real a Git
#

# ==================== API ====================
# URL del backend (cuando lo tengamos)
VITE_API_URL=http://localhost:3000/api

# ==================== APP INFO ====================
VITE_APP_NAME=Fundación de Animales
VITE_APP_VERSION=1.0.0

# ==================== PAYMENT GATEWAYS (para después) ====================
# Stripe (usar test keys mientras desarrollamos)
# VITE_STRIPE_PUBLIC_KEY=pk_test_...

# PayPal
# VITE_PAYPAL_CLIENT_ID=...

# ==================== SERVICES (para después) ====================
# Cloudinary (para imágenes)
# VITE_CLOUDINARY_CLOUD_NAME=...
# VITE_CLOUDINARY_UPLOAD_PRESET=...

# Firebase (para notificaciones)
# VITE_FIREBASE_API_KEY=...
# VITE_FIREBASE_PROJECT_ID=...
# VITE_FIREBASE_MESSAGING_SENDER_ID=...
# VITE_FIREBASE_APP_ID=...

# ==================== FEATURE FLAGS ====================
# Habilitar/deshabilitar funciones en desarrollo
VITE_ENABLE_PAYMENTS=false
VITE_ENABLE_NOTIFICATIONS=false
VITE_USE_MOCK_DATA=true
